      "source": [
        "# @title https://stepik.org/lesson/263806/step/9 Результаты олимпиады (1)\n",
        "lines <- readLines(file(\"stdin\"))\n",
        "\n",
        "# для проверки\n",
        "# lines <- c('5', '1 0 1 2 0') # 3\n",
        "\n",
        "a <- unlist(strsplit(lines[-1], ' '))\n",
        "\n",
        "s <- c()\n",
        "for (x in a) {\n",
        "    if (!(x %in% s)) s <- c(s, x)\n",
        "}\n",
        "\n",
        "cat(length(s))"
      ]
    }
  ]
}